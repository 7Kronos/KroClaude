# KroClaude — copy this file to .env and fill in the values you want.
# `.env` is read automatically by `docker compose`. The real `.env` is gitignored.
# Authoritative reference: specs/001-claude-shell-base/contracts/compose-environment.md

# ----- Required -----
# Anthropic API key used by the Claude Code CLI.
ANTHROPIC_API_KEY=

# ----- Optional: runtime configuration -----
TZ=UTC
GIT_USER_NAME=
GIT_USER_EMAIL=
NODE_OPTIONS=

# ----- Optional: notifications (Apprise URLs) -----
# Off unless BOTH (a) at least one NOTIFY_* is set AND (b) the file
# /home/claude/.claude/notify-on exists inside the container.
# See specs/001-claude-shell-base/contracts/notifications.md.
NOTIFY_URLS=
