#!/usr/bin/env bash
# kc-run — launch a sibling container on the host Docker daemon with
# KroClaude defaults: attach to `kroclaude-apps`, label as managed,
# auto-generate a name if missing, and refuse dangerous flags unless
# --unsafe is passed.
# Contract: specs/004-docker-spawning/contracts/kc-helpers.md
set -euo pipefail

# ---------- Preflight: docker reachable? ----------
DOCKER=docker
if ! docker info >/dev/null 2>&1; then
    if sudo -n docker info >/dev/null 2>&1; then
        DOCKER="sudo -n docker"
    else
        echo "kc-run: docker.sock not available — mount /var/run/docker.sock to use this helper" >&2
        exit 2
    fi
fi

# ---------- Helpers ----------
slug() {
    # Pick a wordlist slug deterministically random; keep it short.
    local words=(quietfox brightoak swiftriver calmwave keenmoss
                 boldlynx warmember crispdune neatkite ruggedfern)
    printf '%s\n' "${words[$((RANDOM % ${#words[@]}))]}"
}

random_hex() {
    head -c 3 /dev/urandom | od -An -tx1 | tr -d ' \n'
}

# Returns 0 if the bind-mount source path is "safe" (under /home/claude,
# /workspace, or /tmp). Returns 1 otherwise.
is_safe_path() {
    case "$1" in
        /home/claude|/home/claude/*) return 0 ;;
        /workspace|/workspace/*)     return 0 ;;
        /tmp|/tmp/*)                 return 0 ;;
        *)                           return 1 ;;
    esac
}

# ---------- Pre-pass: detect --unsafe and strip it from argv ----------
WAS_UNSAFE=0
ARGS=()
for a in "$@"; do
    if [ "$a" = "--unsafe" ]; then
        WAS_UNSAFE=1
    else
        ARGS+=("$a")
    fi
done

# ---------- Main argv scan ----------
HAS_NAME=0
HAS_NETWORK=0
USER_NAME=""
DANGEROUS=()

i=0
n=${#ARGS[@]}
while [ "$i" -lt "$n" ]; do
    arg=${ARGS[$i]}
    case "$arg" in
        # Always-refused: -p / --publish (use kc-forward instead).
        -p|--publish|-p=*|--publish=*)
            echo "kc-run: -p/--publish not supported; use kc-forward instead" >&2
            exit 3
            ;;
        # Dangerous: --privileged
        --privileged)
            DANGEROUS+=("--privileged")
            ;;
        # Dangerous: --network=host  /  --network host
        --network=host)
            DANGEROUS+=("--network=host")
            ;;
        --network)
            HAS_NETWORK=1
            j=$((i + 1))
            if [ "$j" -lt "$n" ]; then
                if [ "${ARGS[$j]}" = "host" ]; then
                    DANGEROUS+=("--network host")
                fi
            fi
            ;;
        --network=*)
            HAS_NETWORK=1
            ;;
        # Dangerous: host namespaces
        --pid=host|--ipc=host|--uts=host|--userns=host)
            DANGEROUS+=("$arg")
            ;;
        --pid|--ipc|--uts|--userns)
            j=$((i + 1))
            if [ "$j" -lt "$n" ] && [ "${ARGS[$j]}" = "host" ]; then
                DANGEROUS+=("$arg host")
            fi
            ;;
        # Dangerous: --cap-add=SYS_ADMIN  /  --cap-add SYS_ADMIN
        --cap-add=SYS_ADMIN)
            DANGEROUS+=("--cap-add=SYS_ADMIN")
            ;;
        --cap-add)
            j=$((i + 1))
            if [ "$j" -lt "$n" ] && [ "${ARGS[$j]}" = "SYS_ADMIN" ]; then
                DANGEROUS+=("--cap-add SYS_ADMIN")
            fi
            ;;
        # Bind-mount inspection: -v <src>:<dst>[:opts] / --volume <…>
        -v|--volume)
            j=$((i + 1))
            if [ "$j" -lt "$n" ]; then
                src=${ARGS[$j]%%:*}
                if [[ "$src" == /* ]] && ! is_safe_path "$src"; then
                    DANGEROUS+=("-v $src")
                fi
            fi
            ;;
        -v=*|--volume=*)
            val=${arg#*=}
            src=${val%%:*}
            if [[ "$src" == /* ]] && ! is_safe_path "$src"; then
                DANGEROUS+=("-v $src")
            fi
            ;;
        --mount)
            j=$((i + 1))
            if [ "$j" -lt "$n" ]; then
                spec=${ARGS[$j]}
                if [[ "$spec" == *type=bind* ]]; then
                    src=$(printf '%s' "$spec" | sed -nE 's/.*source=([^,]+).*/\1/p')
                    if [ -n "$src" ] && [[ "$src" == /* ]] && ! is_safe_path "$src"; then
                        DANGEROUS+=("--mount source=$src")
                    fi
                fi
            fi
            ;;
        --mount=*)
            spec=${arg#*=}
            if [[ "$spec" == *type=bind* ]]; then
                src=$(printf '%s' "$spec" | sed -nE 's/.*source=([^,]+).*/\1/p')
                if [ -n "$src" ] && [[ "$src" == /* ]] && ! is_safe_path "$src"; then
                    DANGEROUS+=("--mount source=$src")
                fi
            fi
            ;;
        # Track --name (don't auto-generate one)
        --name)
            HAS_NAME=1
            j=$((i + 1))
            [ "$j" -lt "$n" ] && USER_NAME=${ARGS[$j]}
            ;;
        --name=*)
            HAS_NAME=1
            USER_NAME=${arg#*=}
            ;;
    esac
    i=$((i + 1))
done

# ---------- Enforce dangerous-flag block (unless --unsafe) ----------
if [ "${#DANGEROUS[@]}" -gt 0 ] && [ "$WAS_UNSAFE" -ne 1 ]; then
    echo "kc-run: ${DANGEROUS[0]} is blocked; pass --unsafe to override (audit-logged)" >&2
    exit 3
fi

# ---------- Inject defaults ----------
DEFAULTS=()
if [ "$HAS_NETWORK" -eq 0 ]; then
    DEFAULTS+=("--network" "kroclaude-apps")
fi
if [ "$HAS_NAME" -eq 0 ]; then
    USER_NAME="kc-$(slug)-$(random_hex)"
    DEFAULTS+=("--name" "$USER_NAME")
fi
DEFAULTS+=("--label" "kroclaude.managed=true")
DEFAULTS+=("--label" "kroclaude.created=$(date -u +%FT%TZ)")

# ---------- Audit line for --unsafe (FR-006b) ----------
if [ "$WAS_UNSAFE" -eq 1 ]; then
    allowed=$(IFS=, ; echo "${DANGEROUS[*]:-}")
    printf '[kc-run UNSAFE] %s user=%s name=%s allowed=%s\n' \
        "$(date -u +%FT%TZ)" "$(whoami)" "$USER_NAME" "$allowed" >&2
fi

# ---------- Print the chosen name (helpful when auto-generated) ----------
if [ "$HAS_NAME" -eq 0 ]; then
    printf 'kc-run: name=%s\n' "$USER_NAME"
fi

# ---------- Forward to docker run ----------
set +e
$DOCKER run "${DEFAULTS[@]}" "${ARGS[@]}"
rc=$?
set -e
[ "$rc" -eq 0 ] && exit 0
exit 4
