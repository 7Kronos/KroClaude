# Source control
.git/
.gitignore

# Spec Kit & docs (not needed in build context)
.specify/
specs/
README.md
CHANGELOG.md
THIRD-PARTY-NOTICES
LICENSE

# CI
.github/

# Tests (run against the built image, not baked into it)
tests/

# NOTE: skills/ is intentionally part of the build context — the
# Dockerfile COPYs it into /usr/local/share/kroclaude/skills/ and the
# entrypoint reflects bundled skills into the persistent volume on
# every container start (feature 002-skill-bundling). Do not add a
# pattern that excludes skills/ here.

# Editor & OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# Runtime data
data/

# Environment files
.env
.env.*
!.env.example

# Compose (the file is read by `docker compose`, not by `docker build`)
docker-compose.yaml
docker-compose.override.yaml
docker-compose.override.yml
